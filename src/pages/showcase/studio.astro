---
import ShowcaseLayout from "../../layouts/ShowcaseLayout.astro";

// Picsum Photos — stable, no hotlink restrictions, deterministic by ID
// https://picsum.photos/id/{id}/{width}/{height}
const cells = [
  { name: "Harlow & Co.", type: "Brand Identity", year: "2025", col: 2, row: 2, img: "https://picsum.photos/id/1018/1200/800" },
  { name: "Portland Civic Center", type: "Wayfinding System", year: "2024", col: 1, row: 1, img: "https://picsum.photos/id/1040/600/600" },
  { name: "Vessel Coffee", type: "Packaging & Identity", year: "2024", col: 1, row: 1, img: "https://picsum.photos/id/431/600/600" },
  { name: "Aldrich Architecture", type: "Identity + Web", year: "2023", col: 1, row: 2, img: "https://picsum.photos/id/1060/600/800" },
  { name: "The Bower Hotel", type: "Environmental Design", year: "2023", col: 2, row: 1, img: "https://picsum.photos/id/164/1200/600" },
  { name: "Cascade Press", type: "Publication Design", year: "2022", col: 1, row: 1, img: "https://picsum.photos/id/24/600/600" },
  { name: "Sonder Spirits", type: "Packaging", year: "2022", col: 1, row: 1, img: "https://picsum.photos/id/312/600/600" },
];
---

<ShowcaseLayout title="Meridian Studio" description="A creative studio.">
  <div style="background-color: #0a0a0a; min-height: 100vh; position: relative">

    <!-- Studio name — fixed, tiny, bottom-left -->
    <div style="position: fixed; bottom: 1.5rem; left: 1.5rem; z-index: 10; pointer-events: none">
      <p style="font-size: 9px; font-weight: 700; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(255,255,255,0.25); font-family: system-ui, sans-serif">Meridian Studio &nbsp;&middot;&nbsp; Portland &nbsp;&middot;&nbsp; Est. 2014</p>
    </div>

    <!-- The grid — full viewport, no text visible -->
    <div id="work-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(3, 28vh); gap: 3px; min-height: 100vh">

      {cells.map(({ name, type, year, col, row, img }) => (
        <div
          class="project-cell"
          data-name={name}
          data-type={type}
          data-year={year}
          style={`grid-column: span ${col}; grid-row: span ${row}; background-color: #111; position: relative; overflow: hidden; cursor: pointer`}
        >
          <img
            src={img}
            alt=""
            class="cell-img"
            style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.3; transition: opacity 0.3s ease"
          />
          <div
            class="cell-overlay"
            style="position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 1.5rem; opacity: 0; transition: opacity 0.25s ease; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 65%)"
          >
            <p class="cell-type" style={`font-size: ${col === 2 && row === 2 ? "10px" : "9px"}; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 0.3rem; font-family: system-ui, sans-serif`}></p>
            <p class="cell-name" style={`font-size: ${col === 2 && row === 2 ? "28px" : col === 2 ? "22px" : row === 2 ? "20px" : "16px"}; font-weight: 600; color: #f0f0f0; line-height: 1.1; letter-spacing: -0.02em; font-family: system-ui, sans-serif`}></p>
            {(col === 2 || row === 2) && (
              <p class="cell-year" style="font-size: 10px; color: rgba(255,255,255,0.35); margin-top: 0.4rem; font-family: system-ui, sans-serif"></p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- About — single paragraph, below the fold -->
    <div style="max-width: 600px; margin: 0 auto; padding: 8vh 2rem 6vh; text-align: center; border-top: 1px solid rgba(255,255,255,0.06)">
      <p style="font-size: 15px; color: rgba(255,255,255,0.35); line-height: 1.9; font-family: system-ui, sans-serif">
        Meridian is a four-person studio in Portland, Oregon. We take on a limited number of projects each year so we can give each one the attention it deserves. Brand identity, print, environmental design, and digital. The medium changes. The standard doesn&rsquo;t.
      </p>
      <a href="#" style="display: inline-block; margin-top: 2rem; font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.5); text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 2px; font-family: system-ui, sans-serif">
        Get in Touch
      </a>
      <p style="font-size: 9px; color: rgba(255,255,255,0.15); margin-top: 3rem; letter-spacing: 0.15em; text-transform: uppercase; font-family: system-ui, sans-serif">
        Built by <a href="/" style="color: rgba(255,255,255,0.3); text-decoration: none">Think Tilted</a>
      </p>
    </div>
  </div>
</ShowcaseLayout>

<script>
  document.querySelectorAll<HTMLElement>(".project-cell").forEach((cell) => {
    const overlay = cell.querySelector<HTMLElement>(".cell-overlay");
    const nameEl = cell.querySelector<HTMLElement>(".cell-name");
    const typeEl = cell.querySelector<HTMLElement>(".cell-type");
    const yearEl = cell.querySelector<HTMLElement>(".cell-year");
    const img = cell.querySelector<HTMLElement>(".cell-img");

    if (nameEl) nameEl.textContent = cell.dataset.name ?? "";
    if (typeEl) typeEl.textContent = cell.dataset.type ?? "";
    if (yearEl) yearEl.textContent = cell.dataset.year ?? "";

    cell.addEventListener("mouseenter", () => {
      if (overlay) overlay.style.opacity = "1";
      if (img) img.style.opacity = "0.65";
      cell.style.filter = "brightness(1.15)";
    });
    cell.addEventListener("mouseleave", () => {
      if (overlay) overlay.style.opacity = "0";
      if (img) img.style.opacity = "0.3";
      cell.style.filter = "brightness(1)";
    });
  });
</script>
