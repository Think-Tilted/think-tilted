---
import ShowcaseLayout from "../../layouts/ShowcaseLayout.astro";
---

<ShowcaseLayout title="Blackbird Supper Club" description="A neighborhood restaurant.">
  <div id="page" style="background-color: #f7f3ec; min-height: 100vh; font-family: Georgia, 'Times New Roman', serif">

    <!-- The menu card — narrow, centered, like holding paper -->
    <div style="max-width: 560px; margin: 0 auto; padding: 6vh 2rem 10vh">

      <!-- Letterhead -->
      <div style="text-align: center; padding: 3rem 0 2.5rem; border-bottom: 1px solid #c8bfb0">
        <p style="font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: #b0835c; margin-bottom: 0.5rem">Portland, Oregon &nbsp;&middot;&nbsp; Est. 2019</p>
        <h1 style="font-size: 22px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; color: #1a1208; margin: 0">Blackbird Supper Club</h1>
        <p style="font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #b0835c; margin-top: 0.5rem">Dinner &nbsp;&middot;&nbsp; Tuesday through Sunday</p>
      </div>

      <!-- Menu section: To Start -->
      <div style="padding: 2.5rem 0 0">
        <p style="font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase; color: #999; margin-bottom: 1.5rem; text-align: center">To Start</p>
        {[
          { name: "Roasted beet & burrata", note: "Gathering Together Farm, hazelnut, aged balsamic", price: "16" },
          { name: "Smoked trout rillettes", note: "Nehalem Bay, rye crisp, crème fraîche, dill", price: "18" },
          { name: "Grilled bread", note: "Ken's Artisan, cultured butter, Jacobsen sea salt", price: "8" },
          { name: "Chicory salad", note: "radicchio, endive, walnut, Rogue Creamery blue", price: "14" },
        ].map(({ name, note, price }) => (
          <div class="dish" style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.9rem 0; border-bottom: 1px solid #e0d8cc; cursor: default; position: relative">
            <div style="flex: 1; padding-right: 1rem">
              <p style="font-size: 15px; color: #1a1208; margin: 0 0 2px">{name}</p>
              <p class="dish-note" style="font-size: 11px; color: #b0835c; font-style: italic; margin: 0; max-height: 0; overflow: hidden; transition: max-height 0.3s ease, opacity 0.3s ease; opacity: 0">{note}</p>
            </div>
            <p style="font-size: 13px; color: #666; flex-shrink: 0; font-style: italic">{price}</p>
          </div>
        ))}
      </div>

      <!-- Menu section: Mains -->
      <div style="padding: 2.5rem 0 0">
        <p style="font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase; color: #999; margin-bottom: 1.5rem; text-align: center">Mains</p>
        {[
          { name: "Wood-roasted chicken", note: "Deck Family Farm, spring onion soubise, jus, herbs", price: "34" },
          { name: "Halibut en papillote", note: "Pacific Coast, fennel, preserved lemon, capers", price: "38" },
          { name: "Braised short rib", note: "Carman Ranch, celery root purée, gremolata, horseradish", price: "42" },
          { name: "Mushroom risotto", note: "Springwater Farm, aged Parmigiano, truffle oil", price: "28" },
        ].map(({ name, note, price }) => (
          <div class="dish" style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.9rem 0; border-bottom: 1px solid #e0d8cc; cursor: default; position: relative">
            <div style="flex: 1; padding-right: 1rem">
              <p style="font-size: 15px; color: #1a1208; margin: 0 0 2px">{name}</p>
              <p class="dish-note" style="font-size: 11px; color: #b0835c; font-style: italic; margin: 0; max-height: 0; overflow: hidden; transition: max-height 0.3s ease, opacity 0.3s ease; opacity: 0">{note}</p>
            </div>
            <p style="font-size: 13px; color: #666; flex-shrink: 0; font-style: italic">{price}</p>
          </div>
        ))}
      </div>

      <!-- Menu section: Dessert -->
      <div style="padding: 2.5rem 0 0">
        <p style="font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase; color: #999; margin-bottom: 1.5rem; text-align: center">To Finish</p>
        {[
          { name: "Chocolate pot de crème", note: "Woodblock Chocolate, fleur de sel, crème fraîche", price: "12" },
          { name: "Seasonal fruit tart", note: "whatever's good right now, almond cream, pastry", price: "11" },
          { name: "Cheese selection", note: "three local cheeses, honeycomb, walnut bread", price: "18" },
        ].map(({ name, note, price }) => (
          <div class="dish" style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.9rem 0; border-bottom: 1px solid #e0d8cc; cursor: default; position: relative">
            <div style="flex: 1; padding-right: 1rem">
              <p style="font-size: 15px; color: #1a1208; margin: 0 0 2px">{name}</p>
              <p class="dish-note" style="font-size: 11px; color: #b0835c; font-style: italic; margin: 0; max-height: 0; overflow: hidden; transition: max-height 0.3s ease, opacity 0.3s ease; opacity: 0">{note}</p>
            </div>
            <p style="font-size: 13px; color: #666; flex-shrink: 0; font-style: italic">{price}</p>
          </div>
        ))}
      </div>

      <!-- Menu footer note -->
      <p style="font-size: 10px; color: #aaa; font-style: italic; text-align: center; margin-top: 2rem; line-height: 1.7">
        Menu changes weekly. We source from local farms whenever possible.<br />
        Dietary accommodations available — please ask your server.
      </p>

      <!-- Divider -->
      <div style="border-top: 1px solid #c8bfb0; margin: 3rem 0" />

      <!-- Reservation block -->
      <div style="text-align: center">
        <p style="font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase; color: #999; margin-bottom: 2rem">Reserve a Table</p>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem">
          <input type="date" style="padding: 10px 12px; border: 1px solid #c8bfb0; background: transparent; font-family: Georgia, serif; font-size: 13px; color: #1a1208; outline: none" />
          <select style="padding: 10px 12px; border: 1px solid #c8bfb0; background: transparent; font-family: Georgia, serif; font-size: 13px; color: #1a1208; outline: none; appearance: none">
            <option>2 guests</option>
            <option>3 guests</option>
            <option>4 guests</option>
            <option>5 guests</option>
            <option>6+ guests</option>
          </select>
        </div>
        <button style="width: 100%; padding: 12px; background-color: #1a1208; color: #f7f3ec; font-family: Georgia, serif; font-size: 13px; letter-spacing: 0.1em; border: none; cursor: pointer">
          Check Availability
        </button>
        <p style="font-size: 10px; color: #aaa; margin-top: 1rem">
          Or call us: (503) 555-0142 &nbsp;&middot;&nbsp; 2847 NE Alberta St
        </p>
      </div>

      <!-- Footer -->
      <div style="border-top: 1px solid #c8bfb0; margin-top: 3rem; padding-top: 1.5rem; text-align: center">
        <p style="font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: #ccc">
          Built by <a href="/" style="color: #b0835c; text-decoration: none">Think Tilted</a>
        </p>
      </div>
    </div>
  </div>
</ShowcaseLayout>

<script>
  document.querySelectorAll(".dish").forEach((dish) => {
    const note = dish.querySelector(".dish-note") as HTMLElement;
    if (!note) return;
    dish.addEventListener("mouseenter", () => {
      note.style.maxHeight = "40px";
      note.style.opacity = "1";
    });
    dish.addEventListener("mouseleave", () => {
      note.style.maxHeight = "0";
      note.style.opacity = "0";
    });
  });
</script>
