---
import ShowcaseLayout from "../../layouts/ShowcaseLayout.astro";
---

<ShowcaseLayout title="The Foundry Fund" description="Building creative infrastructure.">
  <div style="background-color: #ffffff; font-family: system-ui, -apple-system, sans-serif; min-height: 100vh">

    <!-- ABOVE THE FOLD: just the number -->
    <div style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 2rem; position: relative">

      <!-- Org name — tiny, top center -->
      <div style="position: absolute; top: 2rem; left: 50%; transform: translateX(-50%); text-align: center">
        <p style="font-size: 10px; font-weight: 700; letter-spacing: 0.35em; text-transform: uppercase; color: #bbb">The Foundry Fund &nbsp;&middot;&nbsp; 501(c)(3)</p>
      </div>

      <!-- The number — counting up -->
      <div style="text-align: center">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: #5a9e5a; margin-bottom: 1.5rem">Raised toward $500,000</p>
        <div id="counter" style="font-size: clamp(64px, 12vw, 140px); font-weight: 900; color: #0e1f0e; line-height: 1; letter-spacing: -0.04em; font-variant-numeric: tabular-nums">
          $0
        </div>
        <div style="margin-top: 2rem; max-width: 400px; margin-left: auto; margin-right: auto">
          <div style="height: 3px; background-color: #e8e8e8; border-radius: 2px; overflow: hidden">
            <div id="progress-bar" style="height: 3px; background-color: #5a9e5a; border-radius: 2px; width: 0%; transition: width 2s ease-out" />
          </div>
          <div style="display: flex; justify-content: space-between; margin-top: 0.75rem">
            <p style="font-size: 11px; color: #aaa">$0</p>
            <p style="font-size: 11px; color: #aaa">$500,000</p>
          </div>
        </div>
        <p style="font-size: 13px; color: #aaa; margin-top: 1.5rem">Updated in real time &nbsp;&middot;&nbsp; Last gift 4 minutes ago</p>
      </div>

      <!-- Scroll hint -->
      <div style="position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); text-align: center; animation: bounce 2s infinite">
        <p style="font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #ccc; margin-bottom: 0.5rem">Scroll</p>
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#ccc" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>

    <!-- MISSION — below the fold -->
    <div style="max-width: 800px; margin: 0 auto; padding: 10vh 2rem">
      <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 5rem; align-items: start">
        <div>
          <p style="font-size: 10px; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: #5a9e5a; margin-bottom: 0.75rem">Our Mission</p>
          <p style="font-size: 11px; color: #bbb; line-height: 1.8">501(c)(3) nonprofit<br />Founded 2018<br />Portland, Oregon</p>
        </div>
        <div>
          <h2 style="font-size: clamp(26px, 4vw, 44px); font-weight: 800; color: #0e1f0e; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 1.5rem">
            Infrastructure is the work.
          </h2>
          <p style="font-size: 15px; color: #555; line-height: 1.85; margin-bottom: 1.25rem">
            Creative communities don&rsquo;t emerge from nothing. They need space, tools, and time. The Foundry Fund provides all three &mdash; permanently, not temporarily.
          </p>
          <p style="font-size: 15px; color: #555; line-height: 1.85">
            We don&rsquo;t run programs. We build the places where programs happen. Then we hand them to the community and get out of the way.
          </p>
        </div>
      </div>
    </div>

    <!-- MAP — dot map of funded spaces -->
    <div style="background-color: #f8f8f8; padding: 8vh 2rem">
      <div style="max-width: 800px; margin: 0 auto">
        <p style="font-size: 10px; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: #5a9e5a; margin-bottom: 3rem; text-align: center">14 Spaces Across 8 Cities</p>

        <!-- Leaflet map -->
        <div id="foundry-map" style="height: 380px; border-radius: 8px; overflow: hidden"></div>
      </div>
    </div>

    <!-- PROJECTS — table -->
    <div style="max-width: 800px; margin: 0 auto; padding: 8vh 2rem">
      <div style="border-top: 2px solid #0e1f0e; padding-top: 2.5rem; margin-bottom: 0">
        {[
          { city: "Portland, OR", name: "The Albina Workshop", year: "2024", desc: "8,000 sq ft woodworking and fabrication studio", status: "Open" },
          { city: "Detroit, MI", name: "Corktown Print House", year: "2023", desc: "Letterpress, risograph, and screen printing facility", status: "Open" },
          { city: "New Orleans, LA", name: "Tremé Music Studio", year: "2023", desc: "Recording and rehearsal space", status: "Open" },
          { city: "Oakland, CA", name: "Fruitvale Ceramics", year: "2025", desc: "Community ceramics studio, 40 wheels, two kilns", status: "In Progress" },
        ].map(({ city, name, year, desc, status }) => (
          <div style="display: grid; grid-template-columns: 110px 1fr auto; gap: 2rem; align-items: baseline; padding: 1.25rem 0; border-bottom: 1px solid #e8e8e8">
            <div>
              <p style="font-size: 11px; font-weight: 600; color: #5a9e5a">{city}</p>
              <p style="font-size: 10px; color: #bbb">{year}</p>
            </div>
            <div>
              <p style="font-size: 16px; font-weight: 600; color: #0e1f0e; margin-bottom: 2px">{name}</p>
              <p style="font-size: 12px; color: #888">{desc}</p>
            </div>
            <span style={`font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; ${status === "Open" ? "background-color: #e0f0e0; color: #2d6e2d" : "background-color: #f5f5e0; color: #6e6e2d"}`}>
              {status}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- DONATE — fixed bottom-right -->
    <div style="position: fixed; bottom: 2rem; right: 2rem; z-index: 50">
      <a href="#" id="donate-btn" style="display: flex; align-items: center; gap: 0.5rem; background-color: #5a9e5a; color: white; padding: 14px 24px; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; box-shadow: 0 4px 20px rgba(90,158,90,0.4)">
        <span id="donate-pulse" style="width: 8px; height: 8px; background-color: rgba(255,255,255,0.7); border-radius: 50%; display: inline-block; animation: pulse 2s infinite" />
        Give Now
      </a>
    </div>

    <footer style="max-width: 800px; margin: 0 auto; padding: 2rem; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #e8e8e8">
      <p style="font-size: 10px; color: #ccc; letter-spacing: 0.1em; text-transform: uppercase">&copy; 2025 The Foundry Fund &middot; 501(c)(3)</p>
      <p style="font-size: 10px; color: #ccc">Built by <a href="/" style="color: #5a9e5a; text-decoration: none">Think Tilted</a></p>
    </footer>
  </div>
</ShowcaseLayout>

<Fragment slot="head">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</Fragment>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }
  /* Desaturate the map tiles to match the clean white aesthetic */
  #foundry-map { filter: saturate(0.4) brightness(1.05); }
  #foundry-map .leaflet-control-zoom a { color: #5a9e5a; }
</style>

<script>
  // Animated counter
  function animateCounter() {
    const el = document.getElementById("counter");
    const bar = document.getElementById("progress-bar");
    if (!el || !bar) return;

    const target = 320847;
    const duration = 2200;
    const start = performance.now();

    function step(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = Math.floor(eased * target);
      if (el) el.textContent = "$" + value.toLocaleString();
      if (bar) bar.style.width = (eased * 64) + "%";
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  // Start counter when visible
  const counterEl = document.getElementById("counter");
  if (counterEl) {
    const obs = new IntersectionObserver((entries) => {
      const entry = entries[0];
      if (entry && entry.isIntersecting) {
        animateCounter();
        obs.disconnect();
      }
    }, { threshold: 0.5 });
    obs.observe(counterEl);
  }

  // Leaflet map — loaded via global script tag to avoid TS module resolution issues
  declare const L: any;

  const spaces = [
    [45.52, -122.68, "Portland, OR", 3],
    [37.80, -122.27, "Oakland, CA", 2],
    [42.33, -83.05, "Detroit, MI", 2],
    [29.95, -90.07, "New Orleans, LA", 2],
    [41.88, -87.63, "Chicago, IL", 1],
    [33.75, -84.39, "Atlanta, GA", 2],
    [39.74, -104.98, "Denver, CO", 1],
    [39.95, -75.17, "Philadelphia, PA", 1],
  ] as const;

  function initMap() {
    const map = L.map("foundry-map", {
      center: [38.5, -96],
      zoom: 4,
      zoomControl: true,
      scrollWheelZoom: false,
      attributionControl: false,
    });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 18,
    }).addTo(map);

    spaces.forEach(([lat, lng, city, count]) => {
      const radius = 6 + (count as number) * 3;
      const circle = L.circleMarker([lat, lng], {
        radius,
        fillColor: "#5a9e5a",
        color: "#ffffff",
        weight: 2,
        opacity: 1,
        fillOpacity: 0.9,
      }).addTo(map);
      circle.bindTooltip(
        `<strong style="font-size:11px">${city}</strong><br><span style="font-size:10px;color:#888">${count} space${(count as number) > 1 ? "s" : ""}</span>`,
        { direction: "top", offset: [0, -radius] }
      );
    });
  }

  // Wait for Leaflet global to be available
  if (typeof L !== "undefined") {
    initMap();
  } else {
    const script = document.createElement("script");
    script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
    script.onload = initMap;
    document.head.appendChild(script);
  }
</script>
