---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="Think Tilted is a two-brother brand and web studio — identity, design, and the web it lives on."
>
  <section class="py-8 max-w-2xl">
    <h1 class="font-display text-4xl font-semibold tracking-tight text-ink">
      Two brothers, one tilt.
    </h1>
    <p class="mt-6 text-ink-soft leading-relaxed max-w-prose">
      One speaks brand, the other speaks code. You get one team that carries your project from identity to launch.
    </p>
  </section>
</BaseLayout>
