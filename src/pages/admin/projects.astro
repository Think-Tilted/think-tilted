---
import AdminLayout from "../../layouts/AdminLayout.astro";
import StatusPill from "../../components/StatusPill.astro";
import StatusSelect from "../../components/StatusSelect.astro";
import ConfirmButton from "../../components/ConfirmButton.astro";
import { requireAdmin } from "../../lib/admin-auth";
import { flashPath } from "../../lib/flash";
import {
  listProjects,
  createProject,
  setProjectStatus,
  deleteProject,
  listClients,
  formatPrice,
  PROJECT_STATUSES,
  type ProjectStatus,
} from "../../lib/crm";

export const prerender = false;

const gate = await requireAdmin(Astro.request, Astro.cookies, (p) => Astro.redirect(p));
if (gate instanceof Response) return gate;
const { supabase, email } = gate;

let error: string | null = null;
let redirectTo: string | null = null;

if (Astro.request.method === "POST") {

  const form = await Astro.request.formData();
  const intent = String(form.get("intent") ?? "");
  try {
    if (intent === "create") {
      const priceRaw = String(form.get("build_price") ?? "").trim();
      await createProject(supabase, {
        client_id: String(form.get("client_id") ?? "") || null,
        lead_id: null,
        name: String(form.get("name") ?? "").trim(),
        tier: Number(form.get("tier") ?? 1) === 2 ? 2 : 1,
        status: String(form.get("status") ?? "building") as ProjectStatus,
        build_price: priceRaw ? Number(priceRaw) : null,
        care_plan: String(form.get("care_plan") ?? "").trim(),
        repo_url: String(form.get("repo_url") ?? "").trim(),
        site_url: String(form.get("site_url") ?? "").trim(),
      });
      redirectTo = flashPath("/admin/projects", "Project added");
    } else if (intent === "status") {
      await setProjectStatus(
        supabase,
        String(form.get("id") ?? ""),
        String(form.get("status") ?? "building") as ProjectStatus,
      );
      redirectTo = flashPath("/admin/projects", "Status updated");
    } else if (intent === "delete") {
      await deleteProject(supabase, String(form.get("id") ?? ""));
      redirectTo = flashPath("/admin/projects", "Project deleted");
    } else if (intent === "signout") {
      await supabase.auth.signOut();
      return Astro.redirect("/login");
    }
  } catch (e) {
    error = e instanceof Error ? e.message : "Something went wrong.";
  }
  if (!error && redirectTo) return Astro.redirect(redirectTo);
}


const [projects, clients] = await Promise.all([
  listProjects(supabase),
  listClients(supabase),
]);

const clientName = (id: string | null) =>
  id ? (clients.find((c) => c.id === id)?.name ?? "Unlinked") : "—";

const toneFor = (s: ProjectStatus) =>
  s === "live" ? "good" : s === "building" ? "active" : s === "archived" ? "faded" : "warm";
---

<AdminLayout title="Projects" email={email} active="projects">
  <h1 class="font-display text-2xl font-semibold tracking-tight text-ink">Projects</h1>

  {
    error && (
      <p class="mt-4 rounded-md border border-clay/40 bg-clay/5 px-3 py-2 text-sm text-clay">
        {error}
      </p>
    )
  }

  <!-- Add project -->
  <form method="POST" class="mt-8 rounded-xl border border-paper-dim p-5">
    <input type="hidden" name="intent" value="create" />
    <h2 class="font-display text-lg font-semibold text-ink">Add a project</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label for="name" class="block text-sm font-medium text-ink mb-1.5">Project name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        />
      </div>
      <div>
        <label for="client_id" class="block text-sm font-medium text-ink mb-1.5">Client</label>
        <select
          id="client_id"
          name="client_id"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        >
          <option value="">— none —</option>
          {clients.map((c) => <option value={c.id}>{c.name}</option>)}
        </select>
      </div>
      <div>
        <label for="tier" class="block text-sm font-medium text-ink mb-1.5">Tier</label>
        <select
          id="tier"
          name="tier"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        >
          <option value="1">Tier 1 — static</option>
          <option value="2">Tier 2 — dynamic</option>
        </select>
      </div>
      <div>
        <label for="status" class="block text-sm font-medium text-ink mb-1.5">Status</label>
        <select
          id="status"
          name="status"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        >
          {PROJECT_STATUSES.map((s) => (
            <option value={s} selected={s === "building"}>{s}</option>
          ))}
        </select>
      </div>
      <div>
        <label for="build_price" class="block text-sm font-medium text-ink mb-1.5">Build price (USD)</label>
        <input
          id="build_price"
          name="build_price"
          type="number"
          min="0"
          step="100"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        />
      </div>
      <div>
        <label for="care_plan" class="block text-sm font-medium text-ink mb-1.5">Care plan</label>
        <input
          id="care_plan"
          name="care_plan"
          type="text"
          placeholder="e.g. $150/mo dynamic care"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink placeholder:text-ink-muted outline-none focus:border-clay"
        />
      </div>
      <div>
        <label for="repo_url" class="block text-sm font-medium text-ink mb-1.5">Repo URL</label>
        <input
          id="repo_url"
          name="repo_url"
          type="url"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        />
      </div>
      <div>
        <label for="site_url" class="block text-sm font-medium text-ink mb-1.5">Live URL</label>
        <input
          id="site_url"
          name="site_url"
          type="url"
          class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink outline-none focus:border-clay"
        />
      </div>
    </div>
    <button
      type="submit"
      class="mt-4 rounded-lg bg-clay px-4 py-2 text-sm font-medium text-paper transition-colors hover:bg-clay-light"
    >
      Add project
    </button>
  </form>

  {
    projects.length === 0 ? (
      <p class="mt-8 text-sm text-ink-muted">No projects yet.</p>
    ) : (
      <ul class="mt-8 space-y-3">
        {projects.map((project) => (
          <li class="rounded-xl border border-paper-dim p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-3">
                  <h3 class="font-display text-lg font-semibold text-ink">
                    <a href={`/admin/projects/${project.id}`} class="hover:text-clay">{project.name}</a>
                  </h3>
                  <StatusPill label={`Tier ${project.tier}`} tone="neutral" />
                  <StatusPill label={project.status} tone={toneFor(project.status)} />
                </div>
                <p class="mt-1 text-sm text-ink-soft">
                  {clientName(project.client_id)}
                  <span class="text-ink-muted">{" · "}{formatPrice(project.build_price)}</span>
                  {project.care_plan && <span class="text-ink-muted">{" · "}{project.care_plan}</span>}
                </p>
                {(project.repo_url || project.site_url) && (
                  <p class="mt-1 flex gap-4 text-sm">
                    {project.site_url && (
                      <a href={project.site_url} target="_blank" rel="noopener noreferrer" class="text-clay hover:underline">Live ↗</a>
                    )}
                    {project.repo_url && (
                      <a href={project.repo_url} target="_blank" rel="noopener noreferrer" class="text-ink-soft hover:text-clay">Repo ↗</a>
                    )}
                  </p>
                )}
              </div>

              <div class="flex items-center gap-2">
                <StatusSelect id={project.id} current={project.status} options={PROJECT_STATUSES} />
                <form method="POST">
                  <input type="hidden" name="intent" value="delete" />
                  <input type="hidden" name="id" value={project.id} />
                  <ConfirmButton label="✕" confirm="Delete project?" compact />
                </form>
              </div>
            </div>
          </li>
        ))}
      </ul>
    )
  }
</AdminLayout>
