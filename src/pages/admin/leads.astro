---
import AdminLayout from "../../layouts/AdminLayout.astro";
import StatusPill from "../../components/StatusPill.astro";
import StatusSelect from "../../components/StatusSelect.astro";
import { requireAdmin } from "../../lib/admin-auth";
import { flashPath } from "../../lib/flash";
import {
  listLeads,
  setLeadStatus,
  projectTypeLabel,
  formatDate,
  LEAD_STATUSES,
  type LeadStatus,
} from "../../lib/crm";

export const prerender = false;

const gate = await requireAdmin(Astro.request, Astro.cookies, (p) => Astro.redirect(p));
if (gate instanceof Response) return gate;
const { supabase, email } = gate;

let error: string | null = null;
let redirectTo: string | null = null;


if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const intent = String(form.get("intent") ?? "");
  try {
    if (intent === "status") {
      await setLeadStatus(
        supabase,
        String(form.get("id") ?? ""),
        String(form.get("status") ?? "new") as LeadStatus,
      );
      redirectTo = flashPath("/admin/leads", "Lead updated");
    } else if (intent === "signout") {
      await supabase.auth.signOut();
      return Astro.redirect("/login");
    }
  } catch (e) {
    error = e instanceof Error ? e.message : "Something went wrong.";
  }
  if (!error && redirectTo) return Astro.redirect(redirectTo);
}

const leads = await listLeads(supabase);

// Stable pipeline order for the status filter chips.
const counts = LEAD_STATUSES.map((s) => ({
  status: s,
  count: leads.filter((l) => l.status === s).length,
}));

const toneFor = (s: LeadStatus) =>
  s === "new" ? "warm" : s === "won" ? "good" : s === "lost" ? "faded" : "neutral";
---

<AdminLayout title="Leads" email={email} active="leads">
  <div class="flex flex-wrap items-baseline justify-between gap-3">
    <h1 class="font-display text-2xl font-semibold tracking-tight text-ink">Leads</h1>
    <p class="text-sm text-ink-muted">
      {counts.map((c, i) => (
        <span>
          {i > 0 ? " · " : ""}{c.count} {c.status}
        </span>
      ))}
    </p>
  </div>

  {
    error && (
      <p class="mt-4 rounded-md border border-clay/40 bg-clay/5 px-3 py-2 text-sm text-clay">
        {error}
      </p>
    )
  }

  {
    leads.length === 0 ? (
      <p class="mt-10 text-sm text-ink-muted">
        No leads yet. Submissions from the public <a href="/contact" class="underline">contact form</a> land here.
      </p>
    ) : (
      <ul class="mt-8 space-y-4">
        {leads.map((lead) => (
          <li class="rounded-xl border border-paper-dim p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-3">
                  <h2 class="font-display text-lg font-semibold text-ink">
                    <a href={`/admin/leads/${lead.id}`} class="hover:text-clay">{lead.name}</a>
                  </h2>

                  <StatusPill label={lead.status} tone={toneFor(lead.status)} />
                </div>
                <p class="mt-0.5 text-sm text-ink-soft">
                  <a href={`mailto:${lead.email}`} class="hover:text-clay">{lead.email}</a>
                  <span class="text-ink-muted">
                    {" · "}{projectTypeLabel(lead.project_type)}{" · "}{formatDate(lead.created_at)}
                  </span>
                </p>
              </div>

              <StatusSelect id={lead.id} current={lead.status} options={LEAD_STATUSES} />
            </div>

            {lead.message && (
              <p class="mt-3 whitespace-pre-line border-t border-paper-dim pt-3 text-sm text-ink-soft">
                {lead.message}
              </p>
            )}
          </li>
        ))}
      </ul>
    )
  }
</AdminLayout>
