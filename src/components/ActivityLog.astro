---
// The append-only activity log shared by every detail page. It renders the
// timeline and the "add note" box; the parent page owns the POST handling
// (intents "note" and "note-delete") so all mutations stay in one place.
import { formatDateTime, type Note } from "../lib/crm";
import ConfirmButton from "./ConfirmButton.astro";

interface Props {
  notes: Note[];
}

const { notes } = Astro.props;
---

<section id="activity" class="mt-10 scroll-mt-8">
  <h2 class="font-display text-lg font-semibold text-ink">Activity</h2>

  <form method="POST" class="mt-4">
    <input type="hidden" name="intent" value="note" />
    <label for="note-body" class="sr-only">Add a note</label>
    <textarea
      id="note-body"
      name="body"
      rows="2"
      required
      placeholder="Log a call, an email, a decision…"
      class="w-full rounded-lg border border-paper-dim bg-paper px-3 py-2 text-ink placeholder:text-ink-muted outline-none focus:border-clay resize-none"
    ></textarea>
    <button
      type="submit"
      class="mt-2 rounded-lg bg-clay px-4 py-2 text-sm font-medium text-paper transition-colors hover:bg-clay-light"
    >
      Add note
    </button>
  </form>

  {
    notes.length === 0 ? (
      <p class="mt-6 text-sm text-ink-muted">No activity logged yet.</p>
    ) : (
      <ol class="mt-6 space-y-4 border-l border-paper-dim pl-5">
        {notes.map((note) => (
          <li class="relative">
            <span class="absolute -left-[1.6rem] top-1.5 h-2 w-2 rounded-full bg-paper-dark" />
            <div class="flex items-start justify-between gap-4">
              <p class="whitespace-pre-line text-sm text-ink">{note.body}</p>
              <form method="POST" class="shrink-0">
                <input type="hidden" name="intent" value="note-delete" />
                <input type="hidden" name="note_id" value={note.id} />
                <ConfirmButton label="✕" confirm="Delete note?" compact />
              </form>
            </div>
            <p class="mt-0.5 text-xs text-ink-muted">{formatDateTime(note.created_at)}</p>
          </li>
        ))}
      </ol>
    )
  }
</section>
