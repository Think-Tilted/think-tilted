---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Think Tilted — web agency for small businesses" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? import.meta.env.PUBLIC_SITE_URL);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <title>{title} — Think Tilted</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <style>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="min-h-dvh flex flex-col bg-paper text-ink font-sans">
    <header class="mx-auto w-full max-w-5xl px-6 py-6 flex items-center justify-between">
      <a href="/" class="block hover:opacity-80 transition-opacity">
        <img src="/favicon.svg" alt="Think Tilted" class="h-8 w-auto" />
      </a>
      <nav class="flex gap-6 text-sm">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "transition-colors hover:text-clay",
              currentPath === href || (href !== "/" && currentPath.startsWith(href))
                ? "text-clay font-medium"
                : "text-ink-soft",
            ]}
          >
            {label}
          </a>
        ))}
      </nav>
    </header>
    <main class="mx-auto w-full max-w-5xl flex-1 px-6">
      <slot />
    </main>
    <footer class="mx-auto w-full max-w-5xl px-6 py-12 mt-16 border-t border-paper-dim text-sm text-ink-muted flex items-center justify-between">
      <p>&copy; {new Date().getFullYear()} Think Tilted</p>
      <nav class="flex items-center gap-5" aria-label="Social">
        <a
          href="https://instagram.com/thinktilted"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-ink-muted hover:text-ink transition-colors"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        </a>
        <a
          href="https://x.com/thinktilted"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X"
          class="text-ink-muted hover:text-ink transition-colors"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z" />
          </svg>
        </a>
        <a
          href="/contact"
          aria-label="Email"
          class="text-ink-muted hover:text-ink transition-colors"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-10 5L2 7" />
          </svg>
        </a>
      </nav>
    </footer>
  </body>
</html>
